{%- doc -%}
  Renders block content for all blocks that extend the group block.
  (Hover image entegrasyonu yapıldı - Responsive positioning eklendi)

  @param {object} settings - Group block settings
  @param {string} [children] - Rendered children markup
  @param {string} [class] - Additional classes
  @param {string} [style] - Additional inline styles
  @param {string} [shopify_attributes] - Shopify editor attributes
{%- enddoc -%}

<div
  class="
    group-block
    group-block--height-{{ settings.height }}
    group-block--width-{{ settings.width }}
    group-block--content-position-{{ settings.content_position | default: 'bottom' }}
    group-block--d-content-position-{{ settings.content_position | default: 'bottom' }}
    group-block--m-content-position-{{ settings.content_position_mobile | default: settings.content_position | default: 'bottom' }}
    border-style
    spacing-style
    size-style
    {% if settings.background_image_hover != blank %} group-block--has-hover{% endif %}
    {% if settings.inherit_color_scheme == false %} color-{{ settings.color_scheme }}{% endif %}
    {{ class }}
  "
  style="
    {% render 'border-override', settings: settings %}
    {% render 'spacing-style', settings: settings %}
    {% render 'size-style', settings: settings %}
    --hover-speed: {{ settings.hover_transition_speed | default: 0.4 }}s;
    --content-position: {% if settings.content_position == 'top' %}flex-start{% elsif settings.content_position == 'center' %}center{% else %}flex-end{% endif %};
    --vertical-align: {% if settings.content_position == 'top' %}flex-start{% elsif settings.content_position == 'center' %}center{% else %}flex-end{% endif %};
    {{ style }}
  "
  {{ shopify_attributes }}
  data-testid="group-block"
>
  {%- if settings.link != blank -%}
    <a
      href="{{ settings.link }}"
      class="group-block__link"
      {% if settings.open_in_new_tab %}
        target="_blank" rel="noopener"
      {% endif %}
    ></a>
  {%- endif -%}

  <div class="group-block__media-wrapper">
    {%- comment -%} Ana Görsel / Video {%- endcomment -%}
    <div class="group-block__media-main">
      {% render 'background-media',
        background_media: settings.background_media,
        background_video: settings.video,
        background_video_position: settings.video_position,
        background_image: settings.background_image,
        background_image_position: settings.background_image_position,
        placeholder: settings.placeholder
      %}
    </div>

    {%- comment -%} Hover Görseli {%- endcomment -%}
    {% if settings.background_media == 'image' and settings.background_image_hover != blank %}
      <div class="group-block__media-hover">
        {% render 'background-media',
          background_media: 'image',
          background_image: settings.background_image_hover,
          background_image_position: settings.background_image_position
        %}
      </div>
    {% endif %}

    {% if settings.toggle_overlay %}
      {% render 'overlay', settings: settings, layer: '0' %}
    {% endif %}
  </div>

  <div
    class="
      group-block-content
      {% if request.design_mode %}group-block-content--design-mode{% endif %}
      layout-panel-flex
      layout-panel-flex--{{ settings.content_direction | default: 'column' }}
      {% if settings.vertical_on_mobile %} mobile-column{% endif %}
    "
    style="{% render 'layout-panel-style', settings: settings %}"
  >
    {{- children -}}
  </div>
</div>

{% stylesheet %}
  .group-block {
    position: relative;
    overflow: visible;
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: auto !important;
    background-color: transparent !important;
  }

  .group-block-content{
    padding: 0 !important;
  }

  /* Desktop - İçerik Resmin Üzerinde */
  @media (min-width: 768px) {
    .group-block {
      overflow: hidden;
    }
    .group-block--content-position-bottom {
      overflow: visible;
    }

    .group-block--content-position-bottom .group-block__media-wrapper {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .group-block--content-position-bottom .group-block-content {
      position: relative;
      z-index: 2;
      align-self: flex-end;
      width: 100%;
    }

    .group-block--content-position-top .group-block__media-wrapper {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .group-block--content-position-top .group-block-content {
      position: relative;
      z-index: 2;
      align-self: flex-start;
      width: 100%;
    }

    .group-block--content-position-center .group-block__media-wrapper {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .group-block--content-position-center .group-block-content {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 2;
      width: 100%;
    }
  }

  /* Mobile - İçerik Resmin Altında */
  @media (max-width: 767px) {
    .group-block {
      position: relative;
      overflow: visible;
      display: flex;
      flex-direction: column;
      justify-content: end;
    }

    .group-block__media-wrapper {
      position: relative;
      width: 100%;
      z-index: 0;
      order: -1;
    }

    .group-block-content {
      position: relative;
      z-index: 2;
      width: 100%;
      order: 1;
      padding: 0 !important;
    }
  }

  .group-block__link {
    position: absolute;
    inset: 0;
    z-index: 5;
  }

  .group-block__media-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Hover Görseli Ayarları */
  .group-block__media-hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--hover-speed, 0.4s) ease-in-out;
    z-index: 1;
  }

  .group-block__media-main {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Hover Durumu */
  .group-block--has-hover:hover .group-block__media-hover {
    opacity: 1;
  }

  /* Link ve İçerik Etkileşimi */
  .group-block__link ~ :is(.group-block-content, .group-block__media-wrapper) {
    pointer-events: none;
  }

  .group-block__link ~ .group-block-content--design-mode {
    pointer-events: auto;
  }

  .group-block-content {
    position: relative;
    z-index: 2;
  }

  .group-block--product-card {
    position: absolute !important;
    inset: 0 !important;
    z-index: 3;
    overflow: hidden;
  }

  @media screen and (max-width: 989px) {
    .group-block--product-card {
      position: relative !important;
      inset: auto !important;
      overflow: visible !important;
      z-index: auto !important;
    }

    .group-block--product-card .group-block-content {
      position: relative !important;
      left: auto !important;
      right: auto !important;
      inset: auto !important;
      transform: none !important;
    }
  }
  @media screen and (max-width: 767px) {
    body .group-block--product-card .group-block-content {
      position: relative !important;
      inset: auto !important;
      overflow: visible !important;
      z-index: auto !important;
    }
    product-card > div > div.group-block.group-block--height-fit.group-block--width-fill.group-block--content-position-bottom.group-block--d-content-position-bottom.group-block--m-content-position-bottom.border-style.spacing-style.size-style.group-block--product-card > div.group-block-content.layout-panel-flex.layout-panel-flex--row.mobile-column > div > div.group-block-content.layout-panel-flex.layout-panel-flex--row.mobile-column > a > div > p {
      text-align: left !important;
    }
  }
  .group-block--product-card .group-block__media-wrapper {
    position: absolute !important;
    inset: 0 !important;
    z-index: 0;
  }

  .group-block--product-card .group-block-content {
    position: absolute !important;
    z-index: 2;
    left: 0 !important;
    right: 0 !important;
    width: 100%;
    height: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start !important;
    text-align: center;
    box-sizing: border-box;
    max-width: 100%;
    padding: max(2px, 4px) !important;
    pointer-events: auto;
  }

  @media screen and (max-width: 750px) {
    .group-block--product-card .group-block-content.layout-panel-flex.layout-panel-flex--row.mobile-column {
      flex-direction: row !important;
      align-items: center;
      justify-content: space-between !important;
      text-align: left;
    }

    .group-block--product-card .group-block-content.layout-panel-flex.layout-panel-flex--row.mobile-column > a[ref='productTitleLink'] {
      width: auto;
      flex: 1 1 auto;
      justify-content: flex-start;
    }

    .group-block--product-card .group-block-content.layout-panel-flex.layout-panel-flex--row.mobile-column > product-price {
      width: auto;
      flex: 0 0 auto;
      justify-content: flex-end;
    }
  }

  .group-block--product-card.group-block--m-content-position-top .group-block-content {
    top: 30px;
    bottom: auto;
    transform: none;
  }

  .group-block--product-card.group-block--m-content-position-bottom .group-block-content {
    top: auto;
    bottom: 30px;
    transform: none;
  }

  .group-block--product-card.group-block--m-content-position-center .group-block-content {
    top: calc(50% - 15px);
    left: 50%;
    right: auto;
    transform: translate(-50%, -50%);
  }

  .group-block--product-card .group-block-content > * {
    order: 10;
    min-width: 0;
  }

  .group-block--product-card .group-block-content > :is(.read-more-wrapper, .text-block):not(product-price) {
    order: 0;
  }

  .group-block--product-card .group-block-content > a[ref='productTitleLink'] {
    order: 1;
    min-height: 44px;
    display: flex;
    align-items: center;
    min-width: 0;
    width: 100%;
    justify-content: center;
  }

  .group-block--product-card .group-block-content > product-price {
    order: 2;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .group-block--product-card .group-block-content > product-swatches {
    order: 3;
    align-self: stretch;
  }

  @media (min-width: 769px) {
    .group-block--product-card.group-block--d-content-position-top .group-block-content {
      top: 30px;
      bottom: auto;
      transform: none;
    }

    .group-block--product-card.group-block--d-content-position-bottom .group-block-content {
      top: auto;
      bottom: 30px;
      transform: none;
    }

    .group-block--product-card.group-block--d-content-position-center .group-block-content {
      top: calc(50% - 15px);
      left: 50%;
      right: auto;
      transform: translate(-50%, -50%);
    }

    .group-block--product-card .group-block-content > a[ref='productTitleLink'],
    .group-block--product-card .group-block-content > product-price {
      width: 100%;
      justify-content: center;
    }
  }
{% endstylesheet %}
