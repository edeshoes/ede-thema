tion.id }} .size-guide-video__placeholder{\n      min-height: 340px;\n    }\n  }\n/* === Size Guide Fine-Tuning Patch === */\n#size-guide-{{ section.id }} .size-guide-shell{\n  border-radius: 15px;\n  border-color: rgba(35,32,27,0.09);\n}\n\n#size-guide-{{ section.id }} .size-guide-table-wrap{\n  border-radius: 10px;\n  border-color: rgba(35,32,27,0.09);\n}\n\n#size-guide-{{ section.id }} .size-guide-accordion{\n  border-radius: 10px;\n  border-color: rgba(35,32,27,0.09);\n}\n\n#size-guide-{{ section.id }} .size-guide-video{\n  border-radius: 10px;\n  border-color: rgba(35,32,27,0.09);\n}\n\n#size-guide-{{ section.id }} .size-guide-title{\n  letter-spacing: -0.015em;\n}\n\n#size-guide-{{ section.id }} .size-guide-table th{\n  letter-spacing: 0.07em;\n}\n\n#size-guide-{{ section.id }} .size-guide-table th,\n#size-guide-{{ section.id }} .size-guide-table td{\n  padding-top: 8px;\n  padding-bottom: 8px;\n}\n\n#size-guide-{{ section.id }} .size-guide-accordion summary{\n  padding-top: 11px;\n  padding-bottom: 11px;\n}\n\n#size-guide-{{ section.id }} .size-guide-accordion summary::after{\n  font-size: 15px;\n  color: #6f665b;\n}\n\n#size-guide-{{ section.id }} .size-guide-accordion__content p{\n  color: #564e45;\n}\n\n@media (max-width: 749px){\n  #size-guide-{{ section.id }} .size-guide-shell{\n    border-radius: 14px;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-table-wrap,\n  #size-guide-{{ section.id }} .size-guide-accordion,\n  #size-guide-{{ section.id }} .size-guide-video{\n    border-radius: 9px;\n  }\n}\n</style>\n\n<script>\n  (function() {\n    const root = document.getElementById('size-guide-{{ section.id }}');\n    if (!root) return;\n\n    const trigger = root.querySelector('.size-guide-trigger');\n    const content = root.querySelector('.size-guide-content');\n    const unitButtons = root.querySelectorAll('.size-guide-unit-toggle button');\n    const rows = root.querySelectorAll('.size-guide-table tbody tr');\n\n    function setOpen(open) {\n      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');\n      content.hidden = !open;\n    }\n\n    trigger.addEventListener('click', function() {\n      const isOpen = trigger.getAttribute('aria-expanded') === 'true';\n      setOpen(!isOpen);\n    });\n\n    unitButtons.forEach(function(button) {\n      button.addEventListener('click', function() {\n        const unit = this.dataset.unit;\n\n        unitButtons.forEach(function(btn) {\n          btn.classList.remove('is-active');\n        });\n        this.classList.add('is-active');\n\n        rows.forEach(function(row) {\n          const cell = row.querySelector('.size-unit-cell');\n          const value = row.dataset[unit];\n          if (!cell || !value) return;\n\n          if (unit === 'mm') cell.textContent = value + ' mm';\n          if (unit === 'cm') cell.textContent = value + ' cm';\n          if (unit === 'inch') cell.textContent = value + ' in';\n        });\n      });\n    });\n\n    setOpen(false);\n  })();\n</script>\n\n<style>\n/* =========================================\n   PRODUCT PAGE – PREMIUM SIZE PICKER PATCH\n   ========================================= */\n\n/* 1) \"Size\" başlığını gizle */\n.product-form__input legend,\n.product-form__input .form__label,\n.variant-picker__legend,\n.variant-picker__label,\n.product__info-container .product-form__input legend,\n.product__info-container .product-form__input .form__label {\n  display: none !important;\n}\n\n/* 2) İstersen yukarıdaki gizleme yerine özel küçük başlık eklemek için\n   aşağıdaki bölümü AÇABİLİRSİN.\n   Şimdilik kapalı bıraktım.\n\n.product-form__input--pill::before,\n.product-form__input--button::before,\n.product-form__input[data-option-name*=\"Size\"]::before,\n.product-form__input[data-option-name*=\"size\"]::before {\n  content: \"US Women Size\";\n  display: block;\n  margin: 0 0 10px 0;\n  font-size: 11px;\n  letter-spacing: .08em;\n  text-transform: uppercase;\n  color: #7b7368;\n  font-weight: 600;\n}\n*/\n\n/* 3)