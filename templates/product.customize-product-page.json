            "custom_liquid_gPDVhU": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<div class=\"size-guide-link\">\n  <button type=\"button\" class=\"size-guide-open\">\n    About size information\n  </button>\n</div>\n\n<div class=\"size-guide-modal\" id=\"sizeGuideModal\" aria-hidden=\"true\">\n  <div class=\"size-guide-overlay\"></div>\n\n  <div class=\"size-guide-dialog\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"sizeGuideTitle\">\n    <button type=\"button\" class=\"size-guide-close\" aria-label=\"Close\">×</button>\n\n    <div class=\"size-guide-wrap\">\n      <div class=\"size-guide-head\">\n        <h2 id=\"sizeGuideTitle\">YOUR FEET DESERVE SHOES MADE JUST FOR THEM</h2>\n        <p>WOMEN'S SIZE CHART</p>\n      </div>\n\n      <div class=\"size-guide-block\">\n        <button class=\"sg-accordion active\" type=\"button\">Size chart</button>\n        <div class=\"sg-panel\" style=\"display:block;\">\n          <div class=\"sg-toggle\">\n            <button class=\"sg-unit active\" data-unit=\"mm\" type=\"button\">MM</button>\n            <button class=\"sg-unit\" data-unit=\"cm\" type=\"button\">CM</button>\n            <button class=\"sg-unit\" data-unit=\"inch\" type=\"button\">INCH</button>\n          </div>\n\n          <table class=\"sg-table\">\n            <thead>\n              <tr>\n                <th>EU</th>\n                <th>US SIZE</th>\n                <th class=\"sg-unit-head\">MM</th>\n              </tr>\n            </thead>\n            <tbody id=\"sg-body\"></tbody>\n          </table>\n        </div>\n      </div>\n\n      <div class=\"size-guide-block\">\n        <button class=\"sg-accordion\" type=\"button\">How to Measure</button>\n        <div class=\"sg-panel\">\n          <p>Place your foot on a sheet of paper.</p>\n          <p>Mark the back of your heel and the tip of your longest toe.</p>\n          <p>Measure the distance in centimeters if possible.</p>\n          <p>Do this for both feet and use the larger value.</p>\n        </div>\n      </div>\n\n      <div class=\"size-guide-block\">\n        <button class=\"sg-accordion\" type=\"button\">Important Notes</button>\n        <div class=\"sg-panel\">\n          <p>We use a special shoe last. It is normal to choose a different size from your current shoe size.</p>\n          <p><strong>Crazy (stiff) leathers:</strong> stretch approximately 2 mm after the first week.</p>\n          <p><strong>Other leathers:</strong> stretch approximately 5 mm after the first week.</p>\n        </div>\n      </div>\n\n      <div class=\"size-guide-help\">\n        <h3>Need help?</h3>\n        <p>Feel free to contact us. We are happy to assist.</p>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n.size-guide-link {\n  margin-top: 12px;\n  margin-bottom: 10px;\n}\n.size-guide-open {\n  background: none;\n  border: 0;\n  padding: 0;\n  font-size: 13px;\n  color: #6f6a63;\n  text-decoration: underline;\n  cursor: pointer;\n}\n\n.size-guide-modal {\n  display: none;\n}\n.size-guide-modal.is-open {\n  display: block;\n}\n.size-guide-overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(0,0,0,.45);\n  z-index: 9998;\n}\n.size-guide-dialog {\n  position: fixed;\n  top: 50%;\n  left: 50%;\n  width: min(920px, calc(100vw - 32px));\n  max-height: calc(100vh - 48px);\n  overflow: auto;\n  transform: translate(-50%, -50%);\n  background: #fff;\n  padding: 32px;\n  z-index: 9999;\n  border-radius: 12px;\n}\n.size-guide-close {\n  position: absolute;\n  top: 14px;\n  right: 16px;\n  background: none;\n  border: 0;\n  font-size: 28px;\n  cursor: pointer;\n  line-height: 1;\n}\n\n.size-guide-wrap {\n  max-width: 760px;\n  margin: 0 auto;\n  color: #222;\n  font-family: Inter, Arial, sans-serif;\n}\n.size-guide-head {\n  text-align: center;\n  margin-bottom: 28px;\n}\n.size-guide-head h2 {\n  font-size: 28px;\n  line-height: 1.2;\n  margin: 0 0 8px 0;\n  letter-spacing: -0.02em;\n}\n.size-guide-head p {\n  margin: 0;\n  opacity: .6;\n  letter-spacing: .04em;\n}\n\n.size-guide-block {\n  border-top: 1px solid #e9e5df;\n}\n.sg-accordion {\n  width: 100%;\n  background: none;\n  border: 0;\n  text-align: left;\n  font-size: 18px;\n  padding: 20px 0;\n  cursor: pointer;\n  position: relative;\n}\n.sg-accordion::after {\n  content: \"+\";\n  position: absolute;\n  right: 0;\n  top: 20px;\n  font-size: 22px;\n}\n.sg-accordion.active::after {\n  content: \"−\";\n}\n.sg-panel {\n  display: none;\n  padding: 0 0 24px 0;\n}\n.sg-toggle {\n  display: flex;\n  gap: 10px;\n  justify-content: flex-end;\n  margin-bottom: 18px;\n}\n.sg-unit {\n  border: 1px solid #ddd6cc;\n  background: #fff;\n  border-radius: 999px;\n  padding: 8px 16px;\n  cursor: pointer;\n}\n.sg-unit.active {\n  background: #f2eee7;\n  border-color: #cfc5b7;\n}\n.sg-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: 15px;\n}\n.sg-table th,\n.sg-table td {\n  padding: 12px 14px;\n  border: 1px solid #ece7df;\n  text-align: left;\n}\n.sg-table th {\n  background: #faf8f4;\n  font-weight: 600;\n}\n.sg-table td:last-child {\n  font-weight: 600;\n  background: #f8f3df;\n}\n.size-guide-help {\n  border-top: 1px solid #e9e5df;\n  margin-top: 8px;\n  padding-top: 24px;\n  text-align: center;\n}\n.size-guide-help h3 {\n  margin: 0 0 8px 0;\n}\n\n@media (max-width: 640px) {\n  .size-guide-dialog {\n    width: calc(100vw - 16px);\n    max-height: calc(100vh - 16px);\n    padding: 20px 16px;\n  }\n  .size-guide-head h2 {\n    font-size: 22px;\n  }\n  .sg-accordion {\n    font-size: 17px;\n  }\n  .sg-table th,\n  .sg-table td {\n    padding: 10px 10px;\n    font-size: 14px;\n  }\n}\n</style>\n\n<script>\n(function() {\n  const rows = [\n    { eu:\"34\", us:\"3.5-4\",  mm:\"219\", cm:\"21.9\", inch:\"8.62\" },\n    { eu:\"35\", us:\"4.5\",    mm:\"225\", cm:\"22.5\", inch:\"8.86\" },\n    { eu:\"36\", us:\"5-5.5\",  mm:\"233\", cm:\"23.3\", inch:\"9.17\" },\n    { eu:\"37\", us:\"6-6.5\",  mm:\"239\", cm:\"23.9\", inch:\"9.41\" },\n    { eu:\"38\", us:\"7-7.5\",  mm:\"245\", cm:\"24.5\", inch:\"9.65\" },\n    { eu:\"39\", us:\"8-8.5\",  mm:\"252\", cm:\"25.2\", inch:\"9.92\" },\n    { eu:\"40\", us:\"9-9.5\",  mm:\"259\", cm:\"25.9\", inch:\"10.20\" },\n    { eu:\"41\", us:\"10-10.5\",mm:\"266\", cm:\"26.6\", inch:\"10.47\" },\n    { eu:\"42\", us:\"11-11.5\",mm:\"274\", cm:\"27.4\", inch:\"10.79\" },\n    { eu:\"43\", us:\"12-12.5\",mm:\"282\", cm:\"28.2\", inch:\"11.10\" },\n    { eu:\"44\", us:\"13-13.5\",mm:\"289\", cm:\"28.9\", inch:\"11.38\" },\n    { eu:\"45\", us:\"14-14.5\",mm:\"296\", cm:\"29.6\", inch:\"11.65\" }\n  ];\n\n  const modal = document.getElementById(\"sizeGuideModal\");\n  const openBtn = document.querySelector(\".size-guide-open\");\n  const closeBtn = document.querySelector(\".size-guide-close\");\n  const overlay = document.querySelector(\".size-guide-overlay\");\n  const body = document.getElementById(\"sg-body\");\n  const head = document.querySelector(\".sg-unit-head\");\n  const unitBtns = document.querySelectorAll(\".sg-unit\");\n\n  function render(unit) {\n    head.textContent = unit.toUpperCase();\n    body.innerHTML = rows.map(r => `\n      <tr>\n        <td>${r.eu}</td>\n        <td>${r.us}</td>\n        <td>${r[unit]}</td>\n      </tr>\n    `).join(\"\");\n  }\n\n  function openModal() {\n    modal.classList.add(\"is-open\");\n    modal.setAttribute(\"aria-hidden\", \"false\");\n    document.body.style.overflow = \"hidden\";\n  }\n\n  function closeModal() {\n    modal.classList.remove(\"is-open\");\n    modal.setAttribute(\"aria-hidden\", \"true\");\n    document.body.style.overflow = \"\";\n  }\n\n  if (openBtn) openBtn.addEventListener(\"click\", openModal);\n  if (closeBtn) closeBtn.addEventListener(\"click\", closeModal);\n  if (overlay) overlay.addEventListener(\"click\", closeModal);\n\n  document.addEventListener(\"keydown\", function(e) {\n    if (e.key === \"Escape\") closeModal();\n  });\n\n  unitBtns.forEach(btn => {\n    btn.addEventListener(\"click\", function() {\n      unitBtns.forEach(b => b.classList.remove(\"active\"));\n      this.classList.add(\"active\");\n      render(this.dataset.unit);\n    });\n  });\n\n  const accs = document.querySelectorAll(\".sg-accordion\");\n  accs.forEach(btn => {\n    btn.addEventListener(\"click\", function() {\n      this.classList.toggle(\"active\");\n      const panel = this.nextElementSibling;\n      panel.style.display = panel.style.display === \"block\" ? \"none\" : \"block\";\n    });\n  });\n\n  render(\"mm\");\n})();\n</script>"
