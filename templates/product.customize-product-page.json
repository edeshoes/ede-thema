roduct-form__input input[type=\"radio\"]:checked + label,\n.product-form__input .swatch-input__input:checked + .swatch-input__label,\n.product-form__input .variant-picker__option-values input[type=\"radio\"]:checked + label,\n.product__info-container .product-form__input input[type=\"radio\"]:checked + label {\n  background: #2b251f !important;\n  color: #fffaf3 !important;\n  border-color: #2b251f !important;\n  box-shadow: 0 1px 0 rgba(43, 37, 31, 0.08), 0 4px 14px rgba(43, 37, 31, 0.10) !important;\n}\n\n/* 8) Klavye ile seçimde net focus */\n.product-form__input input[type=\"radio\"]:focus-visible + label,\n.product-form__input .swatch-input__input:focus-visible + .swatch-input__label,\n.product__info-container .product-form__input input[type=\"radio\"]:focus-visible + label {\n  outline: 2px solid rgba(43, 37, 31, 0.28) !important;\n  outline-offset: 2px !important;\n}\n\n/* 9) Kullanılamayan varyantlar */\n.product-form__input input[type=\"radio\"]:disabled + label,\n.product-form__input .swatch-input__input:disabled + .swatch-input__label,\n.product__info-container .product-form__input input[type=\"radio\"]:disabled + label {\n  opacity: 0.38 !important;\n  cursor: not-allowed !important;\n  text-decoration: none !important;\n  background: #f3eee6 !important;\n}\n\n/* 10) Add to cart butonunu gizle */\n.product-form__buttons button[name=\"add\"],\n.product-form__buttons .product-form__submit,\n.product-form__submit,\nbutton.product-form__submit {\n  display: none !important;\n}\n\n/* 11) Buy it now butonu daha iyi hizalansın */\n.product-form__buttons,\n.shopify-payment-button {\n  margin-top: 10px !important;\n}\n\n.shopify-payment-button,\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  width: 100% !important;\n  min-height: 44px !important;\n  border-radius: 10px !important;\n}\n\n/* 12) Quantity + buy button arası daha temiz dursun */\n.product-form__buttons {\n  display: flex !important;\n  align-items: stretch !important;\n  gap: 10px !important;\n  flex-wrap: wrap !important;\n}\n\n/* 13) Mobil ince ayar */\n@media (max-width: 749px) {\n  .product-form__input input[type=\"radio\"] + label,\n  .product-form__input .swatch-input__label,\n  .product-form__input .block-swatch,\n  .product-form__input .variant-picker__option-values label,\n  .product__info-container .product-form__input input[type=\"radio\"] + label {\n    min-width: 44px !important;\n    min-height: 38px !important;\n    padding: 9px 10px !important;\n    border-radius: 9px !important;\n    font-size: 12.5px !important;\n  }\n\n  .product-form__buttons {\n    gap: 8px !important;\n  }\n\n  .shopify-payment-button,\n  .shopify-payment-button__button,\n  .shopify-payment-button__button--unbranded {\n    min-height: 42px !important;\n    border-radius: 9px !important;\n  }\n}\n</style>"
