              "settings": {
                "custom_liquid": "<div class=\"size-guide-wrap\" id=\"size-guide-{{ section.id }}\">\n  <button type=\"button\" class=\"size-guide-trigger\" aria-expanded=\"false\" aria-controls=\"size-guide-panel-{{ section.id }}\">\n    <span>Size chart</span>\n    <svg class=\"size-guide-trigger-icon\" viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\">\n      <path d=\"M5 8L10 13L15 8\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    </svg>\n  </button>\n\n  <div class=\"size-guide-panel\" id=\"size-guide-panel-{{ section.id }}\" hidden>\n    <button type=\"button\" class=\"size-guide-open\">Open size guide</button>\n  </div>\n\n  <div class=\"size-guide-modal\" hidden>\n    <div class=\"size-guide-backdrop\"></div>\n\n    <div class=\"size-guide-dialog\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"size-guide-title-{{ section.id }}\">\n      <button type=\"button\" class=\"size-guide-close\" aria-label=\"Close size guide\">\n        <svg viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\">\n          <path d=\"M6 6L14 14M14 6L6 14\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\"/>\n        </svg>\n      </button>\n\n      <div class=\"size-guide-header\">\n        <h3 id=\"size-guide-title-{{ section.id }}\">Size Guide</h3>\n\n        <div class=\"size-guide-unit-toggle\" role=\"tablist\" aria-label=\"Measurement units\">\n          <button type=\"button\" class=\"is-active\" data-unit=\"mm\">MM</button>\n          <button type=\"button\" data-unit=\"cm\">CM</button>\n          <button type=\"button\" data-unit=\"inch\">INCH</button>\n        </div>\n      </div>\n\n      <div class=\"size-guide-body\">\n        <div class=\"size-guide-table-wrap\">\n          <table class=\"size-guide-table\">\n            <thead>\n              <tr>\n                <th>US</th>\n                <th>EU</th>\n                <th>Foot Length</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr data-mm=\"230\" data-cm=\"23.0\" data-inch=\"9.06\"><td>6</td><td>36</td><td class=\"size-unit-cell\">230 mm</td></tr>\n              <tr data-mm=\"236\" data-cm=\"23.6\" data-inch=\"9.29\"><td>6.5</td><td>37</td><td class=\"size-unit-cell\">236 mm</td></tr>\n              <tr data-mm=\"243\" data-cm=\"24.3\" data-inch=\"9.57\"><td>7.5</td><td>38</td><td class=\"size-unit-cell\">243 mm</td></tr>\n              <tr data-mm=\"250\" data-cm=\"25.0\" data-inch=\"9.84\"><td>8.5</td><td>39</td><td class=\"size-unit-cell\">250 mm</td></tr>\n              <tr data-mm=\"256\" data-cm=\"25.6\" data-inch=\"10.08\"><td>9</td><td>40</td><td class=\"size-unit-cell\">256 mm</td></tr>\n              <tr data-mm=\"263\" data-cm=\"26.3\" data-inch=\"10.35\"><td>10</td><td>41</td><td class=\"size-unit-cell\">263 mm</td></tr>\n              <tr data-mm=\"270\" data-cm=\"27.0\" data-inch=\"10.63\"><td>11</td><td>42</td><td class=\"size-unit-cell\">270 mm</td></tr>\n              <tr data-mm=\"276\" data-cm=\"27.6\" data-inch=\"10.87\"><td>11.5</td><td>43</td><td class=\"size-unit-cell\">276 mm</td></tr>\n              <tr data-mm=\"283\" data-cm=\"28.3\" data-inch=\"11.14\"><td>12</td><td>44</td><td class=\"size-unit-cell\">283 mm</td></tr>\n              <tr data-mm=\"290\" data-cm=\"29.0\" data-inch=\"11.42\"><td>13</td><td>45</td><td class=\"size-unit-cell\">290 mm</td></tr>\n            </tbody>\n          </table>\n        </div>\n\n        <div class=\"size-guide-accordions\">\n          <details class=\"size-guide-accordion\">\n            <summary>How to measure</summary>\n            <div class=\"size-guide-accordion-content\">\n              Stand on a paper, mark heel and longest toe, then measure the distance in a straight line.\n            </div>\n          </details>\n\n          <details class=\"size-guide-accordion\">\n            <summary>Fit note</summary>\n            <div class=\"size-guide-accordion-content\">\n              If you are between sizes, choose the larger size for a more relaxed fit.\n            </div>\n          </details>\n\n          <details class=\"size-guide-accordion\">\n            <summary>Need help?</summary>\n            <div class=\"size-guide-accordion-content\">\n              Send us your foot length and usual shoe size. We’ll guide you to the best option.\n            </div>\n          </details>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n  #size-guide-{{ section.id }}{\n    margin-top: 10px;\n    margin-bottom: 8px;\n    border-top: 1px solid rgba(0,0,0,.08);\n    padding-top: 10px;\n  }\n\n  #size-guide-{{ section.id }} *{\n    box-sizing: border-box;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-trigger{\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    background: transparent;\n    border: 0;\n    padding: 2px 0 0;\n    margin: 0;\n    font: inherit;\n    color: inherit;\n    cursor: pointer;\n    text-align: left;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-trigger span{\n    font-size: 13px;\n    line-height: 1.4;\n    letter-spacing: .02em;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-trigger-icon{\n    width: 16px;\n    height: 16px;\n    flex: 0 0 16px;\n    transition: transform .2s ease;\n    opacity: .75;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-trigger[aria-expanded=\"true\"] .size-guide-trigger-icon{\n    transform: rotate(180deg);\n  }\n\n  #size-guide-{{ section.id }} .size-guide-panel{\n    padding-top: 8px;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-open{\n    appearance: none;\n    border: 1px solid rgba(0,0,0,.14);\n    background: #fff;\n    color: #111;\n    border-radius: 999px;\n    padding: 8px 14px;\n    font-size: 12px;\n    line-height: 1;\n    cursor: pointer;\n    transition: all .2s ease;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-open:hover{\n    border-color: rgba(0,0,0,.28);\n    transform: translateY(-1px);\n  }\n\n  #size-guide-{{ section.id }} .size-guide-modal{\n    position: fixed;\n    inset: 0;\n    z-index: 9999;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-backdrop{\n    position: absolute;\n    inset: 0;\n    background: rgba(15,15,15,.42);\n    backdrop-filter: blur(2px);\n  }\n\n  #size-guide-{{ section.id }} .size-guide-dialog{\n    position: absolute;\n    left: 50%;\n    top: 50%;\n    transform: translate(-50%,-50%);\n    width: min(760px, calc(100vw - 24px));\n    max-height: min(86vh, 920px);\n    overflow: auto;\n    background: #fff;\n    color: #111;\n    border-radius: 20px;\n    padding: 18px 18px 16px;\n    box-shadow: 0 22px 60px rgba(0,0,0,.18);\n  }\n\n  #size-guide-{{ section.id }} .size-guide-close{\n    position: absolute;\n    top: 12px;\n    right: 12px;\n    width: 34px;\n    height: 34px;\n    display: grid;\n    place-items: center;\n    border: 0;\n    background: transparent;\n    border-radius: 50%;\n    cursor: pointer;\n    color: #111;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-close svg{\n    width: 16px;\n    height: 16px;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-header{\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    padding-right: 34px;\n    margin-bottom: 14px;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-header h3{\n    margin: 0;\n    font-size: 20px;\n    line-height: 1.2;\n    letter-spacing: -.01em;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-unit-toggle{\n    display: inline-flex;\n    align-items: center;\n    gap: 4px;\n    padding: 3px;\n    background: #f5f5f3;\n    border-radius: 999px;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-unit-toggle button{\n    appearance: none;\n    border: 0;\n    background: transparent;\n    color: #555;\n    border-radius: 999px;\n    padding: 7px 11px;\n    font-size: 11px;\n    line-height: 1;\n    letter-spacing: .06em;\n    cursor: pointer;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-unit-toggle button.is-active{\n    background: #111;\n    color: #fff;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-body{\n    display: grid;\n    gap: 12px;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-table-wrap{\n    overflow-x: auto;\n    border: 1px solid rgba(0,0,0,.08);\n    border-radius: 14px;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-table{\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 13px;\n    line-height: 1.35;\n    background: #fff;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-table th,\n  #size-guide-{{ section.id }} .size-guide-table td{\n    padding: 10px 12px;\n    border-bottom: 1px solid rgba(0,0,0,.06);\n    text-align: left;\n    white-space: nowrap;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-table th{\n    font-size: 11px;\n    letter-spacing: .08em;\n    text-transform: uppercase;\n    color: #666;\n    background: #fafaf8;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-table tbody tr:last-child td{\n    border-bottom: 0;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-accordions{\n    display: grid;\n    gap: 8px;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-accordion{\n    border: 1px solid rgba(0,0,0,.08);\n    border-radius: 12px;\n    overflow: hidden;\n    background: #fff;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-accordion summary{\n    list-style: none;\n    cursor: pointer;\n    padding: 12px 14px;\n    font-size: 13px;\n    line-height: 1.35;\n    position: relative;\n    font-weight: 500;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-accordion summary::-webkit-details-marker{\n    display: none;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-accordion summary::after{\n    content: \"+\";\n    position: absolute;\n    right: 14px;\n    top: 50%;\n    transform: translateY(-50%);\n    font-size: 16px;\n    line-height: 1;\n    opacity: .65;\n  }\n\n  #size-guide-{{ section.id }} .size-guide-accordion[open] summary::after{\n    content: \"–\";\n  }\n\n  #size-guide-{{ section.id }} .size-guide-accordion-content{\n    padding: 0 14px 13px;\n    font-size: 12px;\n    line-height: 1.55;\n    color: #555;\n  }\n\n  body.size-guide-lock{\n    overflow: hidden;\n  }\n\n  @media (max-width: 749px){\n    #size-guide-{{ section.id }}{\n      margin-top: 8px;\n      padding-top: 8px;\n    }\n\n    #size-guide-{{ section.id }} .size-guide-dialog{\n      width: calc(100vw - 16px);\n      padding: 16px 14px 14px;\n      border-radius: 16px;\n      max-height: 88vh;\n    }\n\n    #size-guide-{{ section.id }} .size-guide-header{\n      align-items: flex-start;\n      flex-direction: column;\n      padding-right: 30px;\n      gap: 10px;\n    }\n\n    #size-guide-{{ section.id }} .size-guide-header h3{\n      font-size: 18px;\n    }\n\n    #size-guide-{{ section.id }} .size-guide-table th,\n    #size-guide-{{ section.id }} .size-guide-table td{\n      padding: 9px 10px;\n      font-size: 12px;\n    }\n  }\n</style>\n\n<script>\n  (function() {\n    const root = document.getElementById('size-guide-{{ section.id }}');\n    if (!root) return;\n\n    const trigger = root.querySelector('.size-guide-trigger');\n    const panel = root.querySelector('.size-guide-panel');\n    const openBtn = root.querySelector('.size-guide-open');\n    const modal = root.querySelector('.size-guide-modal');\n    const backdrop = root.querySelector('.size-guide-backdrop');\n    const closeBtn = root.querySelector('.size-guide-close');\n    const unitButtons = root.querySelectorAll('.size-guide-unit-toggle button');\n    const rows = root.querySelectorAll('.size-guide-table tbody tr');\n\n    function setExpanded(isExpanded) {\n      trigger.setAttribute('aria-expanded', isExpanded ? 'true' : 'false');\n      panel.hidden = !isExpanded;\n    }\n\n    function openModal() {\n      modal.hidden = false;\n      document.body.classList.add('size-guide-lock');\n    }\n\n    function closeModal() {\n      modal.hidden = true;\n      document.body.classList.remove('size-guide-lock');\n    }\n\n    trigger.addEventListener('click', function() {\n      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';\n      setExpanded(!isExpanded);\n    });\n\n    openBtn.addEventListener('click', openModal);\n    closeBtn.addEventListener('click', closeModal);\n    backdrop.addEventListener('click', closeModal);\n\n    document.addEventListener('keydown', function(e) {\n      if (e.key === 'Escape' && !modal.hidden) closeModal();\n    });\n\n    unitButtons.forEach(function(button) {\n      button.addEventListener('click', function() {\n        const unit = this.dataset.unit;\n\n        unitButtons.forEach(function(btn) {\n          btn.classList.remove('is-active');\n        });\n        this.classList.add('is-active');\n\n        rows.forEach(function(row) {\n          const cell = row.querySelector('.size-unit-cell');\n          const value = row.dataset[unit];\n          if (!cell || !value) return;\n\n          if (unit === 'mm') cell.textContent = value + ' mm';\n          if (unit === 'cm') cell.textContent = value + ' cm';\n          if (unit === 'inch') cell.textContent = value + ' in';\n        });\n      });\n    });\n\n    setExpanded(false);\n  })();\n</script>"
