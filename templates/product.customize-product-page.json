                "custom_liquid": "<style>\n/* =========================================\n   EDE – SIZE PICKER FINAL\n   Bu blok size-picker Custom Liquid'inin TAMAMI olsun\n   ========================================= */\n\n/* Native başlıkları gizle */\n.variant-picker__option-info,\n.variant-option__label,\n.variant-picker__label,\n.product-info__block-item legend,\n.product-info__block-item .form__label {\n  display: none !important;\n}\n\n/* Seçenek alanı */\n.product-info__block-item .variant-option--equal-width-buttons,\n.variant-option--equal-width-buttons {\n  position: relative !important;\n  display: grid !important;\n  grid-template-columns: repeat(7, minmax(0, 1fr)) !important;\n  gap: 10px !important;\n  width: 100% !important;\n  max-width: 100% !important;\n  margin: 0 0 10px 0 !important;\n  padding-top: 24px !important;\n  justify-items: stretch !important;\n  align-items: start !important;\n}\n\n/* Kendi başlığımız */\n.product-info__block-item .variant-option--equal-width-buttons::before,\n.variant-option--equal-width-buttons::before {\n  content: \"US Women Size\" !important;\n  position: absolute !important;\n  top: 0 !important;\n  right: 0 !important;\n  display: block !important;\n  font-size: 11px !important;\n  line-height: 1.1 !important;\n  letter-spacing: .10em !important;\n  text-transform: uppercase !important;\n  color: #7b7368 !important;\n  font-weight: 600 !important;\n  text-align: right !important;\n}\n\n/* Input görünmesin ama çalışsın */\n.product-info__block-item .variant-option--equal-width-buttons label.variant-option__button-label input[type=\"radio\"],\n.variant-option--equal-width-buttons label.variant-option__button-label input[type=\"radio\"] {\n  position: absolute !important;\n  opacity: 0 !important;\n  pointer-events: none !important;\n}\n\n/* Kutular */\n.product-info__block-item .variant-option--equal-width-buttons label.variant-option__button-label,\n.variant-option--equal-width-buttons label.variant-option__button-label {\n  width: 100% !important;\n  min-width: 0 !important;\n  height: 50px !important;\n  padding: 0 10px !important;\n  border-radius: 12px !important;\n  border: 1px solid rgba(43, 37, 31, 0.16) !important;\n  background: linear-gradient(180deg, #fcfaf6 0%, #f3ece2 100%) !important;\n  color: #2b251f !important;\n  font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Inter, Helvetica, Arial, sans-serif !important;\n  font-size: 16px !important;\n  font-weight: 600 !important;\n  letter-spacing: -0.02em !important;\n  line-height: 1 !important;\n  display: inline-flex !important;\n  align-items: center !important;\n  justify-content: center !important;\n  text-align: center !important;\n  cursor: pointer !important;\n  box-shadow:\n    0 1px 0 rgba(255,255,255,.72) inset,\n    0 1px 2px rgba(43,37,31,.03) !important;\n  transition:\n    transform .16s ease,\n    background-color .18s ease,\n    border-color .18s ease,\n    color .18s ease,\n    box-shadow .18s ease !important;\n  overflow: hidden !important;\n}\n\n/* Tema pseudo katmanları kapansın */\n.product-info__block-item .variant-option--equal-width-buttons label.variant-option__button-label::before,\n.product-info__block-item .variant-option--equal-width-buttons label.variant-option__button-label::after,\n.variant-option--equal-width-buttons label.variant-option__button-label::before,\n.variant-option--equal-width-buttons label.variant-option__button-label::after {\n  content: none !important;\n  display: none !important;\n}\n\n/* Hover */\n.product-info__block-item .variant-option--equal-width-buttons label.variant-option__button-label:not(:has(input:checked)):hover,\n.variant-option--equal-width-buttons label.variant-option__button-label:not(:has(input:checked)):hover {\n  background: linear-gradient(180deg, #faf5ed 0%, #eee4d8 100%) !important;\n  border-color: rgba(43, 37, 31, 0.24) !important;\n  color: #241f1a !important;\n  transform: translateY(-1px) !important;\n  box-shadow: 0 6px 16px rgba(43,37,31,0.06) !important;\n}\n\n/* Seçili durum */\n.product-info__block-item .variant-option--equal-width-buttons label.variant-option__button-label:has(input:checked),\n.variant-option--equal-width-buttons label.variant-option__button-label:has(input:checked) {\n  background: linear-gradient(180deg, #2a241f 0%, #171310 100%) !important;\n  color: #fffaf3 !important;\n  border-color: #1c1713 !important;\n  transform: translateY(-1px) !important;\n  box-shadow:\n    0 1px 0 rgba(255,255,255,0.06) inset,\n    0 8px 18px rgba(23,19,16,0.16) !important;\n}\n\n/* İçerideki text rengi miras alsın */\n.product-info__block-item .variant-option--equal-width-buttons label.variant-option__button-label *,\n.variant-option--equal-width-buttons label.variant-option__button-label * {\n  color: inherit !important;\n  background: transparent !important;\n}\n\n/* Add to cart gizle */\nbutton[name=\"add\"],\n.product-form__submit,\n.product-form__buttons button[name=\"add\"] {\n  display: none !important;\n}\n\n/* Quantity + Buy now */\n.product-form__buttons {\n  display: flex !important;\n  flex-direction: row !important;\n  align-items: center !important;\n  justify-content: flex-start !important;\n  gap: 8px !important;\n  margin-top: 10px !important;\n}\n\nquantity-selector,\n.quantity,\n.product-form__quantity,\n.quantity-input {\n  width: 104px !important;\n  min-width: 104px !important;\n  max-width: 104px !important;\n  flex: 0 0 104px !important;\n  margin: 0 !important;\n}\n\n.shopify-payment-button {\n  width: auto !important;\n  flex: 0 1 170px !important;\n  margin: 0 !important;\n}\n\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  min-height: 46px !important;\n  border-radius: 12px !important;\n  font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Inter, Helvetica, Arial, sans-serif !important;\n  font-size: 14px !important;\n  font-weight: 600 !important;\n}\n\n/* Mobil */\n@media (max-width: 749px) {\n  .product-info__block-item .variant-option--equal-width-buttons,\n  .variant-option--equal-width-buttons {\n    grid-template-columns: repeat(5, minmax(0, 1fr)) !important;\n    gap: 8px !important;\n    padding-top: 22px !important;\n  }\n\n  .product-info__block-item .variant-option--equal-width-buttons::before,\n  .variant-option--equal-width-buttons::before {\n    right: auto !important;\n    left: 0 !important;\n    text-align: left !important;\n  }\n\n  .product-info__block-item .variant-option--equal-width-buttons label.variant-option__button-label,\n  .variant-option--equal-width-buttons label.variant-option__button-label {\n    height: 46px !important;\n    font-size: 15px !important;\n    border-radius: 11px !important;\n  }\n\n  .product-form__buttons {\n    flex-direction: column !important;\n    align-items: stretch !important;\n    gap: 10px !important;\n  }\n\n  quantity-selector,\n  .quantity,\n  .product-form__quantity,\n  .quantity-input,\n  .shopify-payment-button {\n    width: 100% !important;\n    max-width: 100% !important;\n    min-width: 0 !important;\n    flex: 1 1 auto !important;\n  }\n}\n</style>\n<style>\n/* =========================================\n   EDE – MICRO CLEANUP PATCH\n   sadece ince ayar\n   ========================================= */\n\n/* Size alanı üst boşluğu biraz toparla */\n.variant-option--equal-width-buttons {\n  margin-bottom: 6px !important;\n}\n\n/* Kendi küçük başlığımızı kutulara biraz yaklaştır */\n.variant-option--equal-width-buttons::before {\n  margin-bottom: 8px !important;\n}\n\n/* Size guide üst-alt boşluklarını sıkılaştır */\n#size-guide-{{ section.id }} {\n  margin-top: 8px !important;\n  margin-bottom: 8px !important;\n  padding-top: 8px !important;\n}\n\n/* Quantity + Buy now sola ve birbirine yakın */\n.product-form__buttons {\n  display: flex !important;\n  flex-direction: row !important;\n  justify-content: flex-start !important;\n  align-items: center !important;\n  gap: 6px !important;\n  margin-top: 8px !important;\n}\n\n/* Adet kutusu kompakt */\nquantity-selector,\n.quantity,\n.product-form__quantity,\n.quantity-input {\n  width: 84px !important;\n  min-width: 84px !important;\n  max-width: 84px !important;\n  flex: 0 0 84px !important;\n  margin: 0 !important;\n}\n\n/* Buy now kutuya yaklaşsın */\n.shopify-payment-button {\n  width: auto !important;\n  flex: 0 1 148px !important;\n  margin: 0 !important;\n}\n\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  min-height: 42px !important;\n  border-radius: 10px !important;\n}\n\n/* Mobilde yine alt alta kalsın */\n@media (max-width: 749px) {\n  .product-form__buttons {\n    flex-direction: column !important;\n    align-items: stretch !important;\n    gap: 8px !important;\n  }\n\n  quantity-selector,\n  .quantity,\n  .product-form__quantity,\n  .quantity-input,\n  .shopify-payment-button {\n    width: 100% !important;\n    max-width: 100% !important;\n    min-width: 0 !important;\n    flex: 1 1 auto !important;\n  }\n}\n</style>\n\n<script>\n/* \"Shoe size\" yazısını metne göre kaldır */\n(function () {\n  function hideExactShoeSizeText() {\n    const els = Array.from(document.querySelectorAll('div, span, label, legend, p'));\n    els.forEach(el => {\n      const txt = (el.textContent || '').replace(/\\s+/g, ' ').trim().toLowerCase();\n      if (txt === 'shoe size') {\n        el.style.display = 'none';\n      }\n    });\n  }\n\n  document.addEventListener('DOMContentLoaded', hideExactShoeSizeText);\n\n  const observer = new MutationObserver(hideExactShoeSizeText);\n  observer.observe(document.body, { childList: true, subtree: true });\n})();\n</script>\n\n<style>\n/* Buy now'ı quantity kutusuna yaklaştır */\n.product-form__buttons {\n  display: flex !important;\n  flex-direction: row !important;\n  justify-content: flex-start !important;\n  align-items: center !important;\n  gap: 6px !important;\n}\n\n.shopify-payment-button {\n  width: auto !important;\n  flex: 0 0 auto !important;\n  margin: 0 !important;\n}\n\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  width: 150px !important;\n  min-width: 150px !important;\n  max-width: 150px !important;\n}\n</style>\n\n<style>\n/* Quantity kutusunu Buy now'a yaklaştır */\n.product-form__buttons {\n  display: flex !important;\n  flex-direction: row !important;\n  align-items: center !important;\n  justify-content: flex-start !important;\n}\n\nquantity-selector,\n.quantity,\n.product-form__quantity,\n.quantity-input {\n  width: 84px !important;\n  min-width: 84px !important;\n  max-width: 84px !important;\n  flex: 0 0 84px !important;\n  margin-left: 220px !important;\n  margin-right: 6px !important;\n}\n\n.shopify-payment-button {\n  width: auto !important;\n  flex: 0 0 auto !important;\n  margin: 0 !important;\n}\n\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  width: 150px !important;\n  min-width: 150px !important;\n  max-width: 150px !important;\n}\n\n@media (max-width: 749px) {\n  quantity-selector,\n  .quantity,\n  .product-form__quantity,\n  .quantity-input {\n    margin-left: 0 !important;\n    margin-right: 0 !important;\n  }\n}\n</style>\n\n<style>\n/* Buy now yanındaki ilk bloğu yaklaştır */\n.product-form__buttons {\n  display: flex !important;\n  flex-direction: row !important;\n  align-items: center !important;\n  justify-content: flex-start !important;\n  gap: 6px !important;\n}\n\n/* Buy now'dan önce gelen ilk eleman = adet alanı */\n.product-form__buttons > *:first-child {\n  margin-right: 6px !important;\n}\n\n/* Buy now biraz sabit kalsın */\n.product-form__buttons > *:last-child,\n.shopify-payment-button {\n  flex: 0 0 auto !important;\n}\n\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  width: 150px !important;\n  min-width: 150px !important;\n  max-width: 150px !important;\n}\n</style>\n\n<style>\n/* Mobile dahil quantity + Buy now yan yana */\n.product-form__buttons {\n  display: flex !important;\n  flex-direction: row !important;\n  align-items: center !important;\n  justify-content: flex-start !important;\n  gap: 6px !important;\n}\n\n/* Quantity'nin gerçek elementi */\nquantity-selector-component.quantity-selector {\n  width: 84px !important;\n  min-width: 84px !important;\n  max-width: 84px !important;\n  flex: 0 0 84px !important;\n  margin: 0 !important;\n}\n\n/* Buy now sabit ve quantity'ye yakın */\n.shopify-payment-button {\n  width: auto !important;\n  flex: 0 0 auto !important;\n  margin: 0 !important;\n}\n\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  width: 150px !important;\n  min-width: 150px !important;\n  max-width: 150px !important;\n  margin: 0 !important;\n}\n\n/* Daha önce yazılmış mobilde alt alta dizen kuralı ez */\n@media (max-width: 749px) {\n  .product-form__buttons {\n    flex-direction: row !important;\n    align-items: center !important;\n    justify-content: flex-start !important;\n    gap: 6px !important;\n  }\n\n  quantity-selector-component.quantity-selector {\n    width: 84px !important;\n    min-width: 84px !important;\n    max-width: 84px !important;\n    flex: 0 0 84px !important;\n  }\n\n  .shopify-payment-button {\n    width: auto !important;\n    flex: 0 0 auto !important;\n  }\n\n  .shopify-payment-button__button,\n  .shopify-payment-button__button--unbranded {\n    width: 150px !important;\n    min-width: 150px !important;\n    max-width: 150px !important;\n  }\n}\n</style>\n\n<style>\n/* STEP 1 — quantity kutusunu düzelt ve buy now'a yaklaştır */\n\n.product-form__buttons {\n  display: flex !important;\n  flex-direction: row !important;\n  align-items: center !important;\n  justify-content: flex-start !important;\n  gap: 8px !important;\n}\n\n.product-form__buttons > * {\n  flex: 0 0 auto !important;\n  margin: 0 !important;\n}\n\n/* Gerçek quantity bileşeni */\nquantity-selector-component.quantity-selector {\n  display: inline-flex !important;\n  align-items: center !important;\n  justify-content: center !important;\n  width: 96px !important;\n  min-width: 96px !important;\n  max-width: 96px !important;\n  overflow: hidden !important;\n}\n\n/* İçindeki - sayı + düzeni */\nquantity-selector-component.quantity-selector button {\n  width: 28px !important;\n  min-width: 28px !important;\n  max-width: 28px !important;\n  padding: 0 !important;\n}\n\nquantity-selector-component.quantity-selector input {\n  width: 40px !important;\n  min-width: 40px !important;\n  max-width: 40px !important;\n  text-align: center !important;\n  padding: 0 !important;\n}\n\n/* Buy now sabit kalsın */\n.shopify-payment-button {\n  width: auto !important;\n  flex: 0 0 auto !important;\n  margin: 0 !important;\n}\n\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  width: 146px !important;\n  min-width: 146px !important;\n  max-width: 146px !important;\n}\n</style>\n\n<style>\n/* Buy now wrapper genişliğini kır */\n.accelerated-checkout-block {\n  width: auto !important;\n  max-width: max-content !important;\n  display: inline-flex !important;\n}\n\n/* Buton grubu sola toplansın */\n.product-form__buttons {\n  display: flex !important;\n  align-items: center !important;\n  justify-content: flex-start !important;\n  gap: 6px !important;\n}\n\n/* Quantity */\nquantity-selector-component.quantity-selector {\n  flex: 0 0 auto !important;\n}\n\n/* Buy now iç buton */\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  width: 150px !important;\n}\n</style>\n\n<style>\n/* ANA WRAPPER'I KONTROL ET */\n.product-form-buttons {\n  display: flex !important;\n  flex-direction: row !important;\n  justify-content: flex-start !important; /* Sola topla */\n  align-items: center !important;\n  gap: px !important;\n  width: auto !important; /* full width kır */\n}\n\n/* TÜM ÇOCUKLARI YAYILMAKTAN KURTAR */\n.product-form-buttons > * {\n  flex: 0 0 auto !important;\n  width: auto !important;\n  max-width: none !important;\n}\n\n/* BUY NOW BLOCK YAYILMASIN */\n.accelerated-checkout-block {\n  width: auto !important;\n  flex: 0 0 auto !important;\n  margin: 0 !important;\n}\n\n/* SHOPIFY PAYMENT WRAPPER */\n.shopify-payment-button {\n  width: auto !important;\n  display: inline-block !important;\n}\n\n/* BUTON */\n.shopify-payment-button__button {\n  width: 150px !important;\n}\n</style>\n\n<style>\n/* Quantity kutusu – temiz premium görünüm */\n.quantity-selector {\n  border-radius: 10px !important;\n  border: 1px solid rgba(0,0,0,0.12) !important;\n  background: #ffffff !important;\n  overflow: hidden !important;\n  box-shadow: 0 1px 2px rgba(0,0,0,0.04) !important;\n}\n\n.quantity-selector button {\n  background: transparent !important;\n  border: 0 !important;\n}\n\n.quantity-selector input {\n  background: transparent !important;\n  border: 0 !important;\n  text-align: center !important;\n}\n</style>\n\n<style>\n/* Quantity kutusu – premium refinement */\n.quantity-selector {\n  border-radius: 12px !important;\n  border: 1px solid rgba(43, 37, 31, 0.14) !important;\n  background: linear-gradient(180deg, #fffdf9 0%, #f4ede3 100%) !important;\n  box-shadow:\n    0 1px 0 rgba(255,255,255,0.75) inset,\n    0 2px 6px rgba(43,37,31,0.05) !important;\n  overflow: hidden !important;\n}\n\n.quantity-selector button {\n  width: 30px !important;\n  min-width: 30px !important;\n  max-width: 30px !important;\n  color: #2b251f !important;\n  opacity: 0.82 !important;\n  transition: background-color .18s ease, opacity .18s ease, transform .12s ease !important;\n}\n\n.quantity-selector button:hover {\n  background: rgba(43, 37, 31, 0.05) !important;\n  opacity: 1 !important;\n}\n\n.quantity-selector input {\n  font-size: 14px !important;\n  font-weight: 600 !important;\n  letter-spacing: -0.01em !important;\n  color: #2b251f !important;\n}\n\n/* Buy now da quantity ile aynı aileden görünsün */\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  border-radius: 12px !important;\n  box-shadow:\n    0 1px 0 rgba(255,255,255,0.05) inset,\n    0 4px 10px rgba(0,0,0,0.10) !important;\n  transition: transform .18s ease, box-shadow .18s ease !important;\n}\n\n.shopify-payment-button__button:hover,\n.shopify-payment-button__button--unbranded:hover {\n  transform: translateY(-1px) !important;\n  box-shadow:\n    0 1px 0 rgba(255,255,255,0.05) inset,\n    0 8px 16px rgba(0,0,0,0.14) !important;\n}\n</style>\n\n<style>\n/* Quantity daha ferah */\n.quantity-selector {\n  height: 48px !important;\n  padding: 0 6px !important;\n}\n\n/* + - butonları */\n.quantity-selector button {\n  width: 36px !important;\n  min-width: 36px !important;\n  max-width: 36px !important;\n  height: 36px !important;\n  border-radius: 8px !important;\n}\n\n/* ortadaki sayı */\n.quantity-selector input {\n  font-size: 15px !important;\n  font-weight: 600 !important;\n  height: 36px !important;\n  padding: 0 6px !important;\n}\n\n/* iç spacing dengesi */\n.quantity-selector {\n  display: flex !important;\n  align-items: center !important;\n  gap: 4px !important;\n}\n</style>\n\n<style>\n/* Quantity + Buy now aynı aileden, daha ferah */\n\n.quantity-selector {\n  height: 50px !important;\n  min-height: 50px !important;\n  border-radius: 14px !important;\n  border: 1px solid rgba(43, 37, 31, 0.12) !important;\n  background: linear-gradient(180deg, #fcfaf6 0%, #f3ece2 100%) !important;\n  box-shadow:\n    0 1px 0 rgba(255,255,255,0.72) inset,\n    0 2px 6px rgba(43,37,31,0.05) !important;\n  overflow: hidden !important;\n  display: flex !important;\n  align-items: center !important;\n  gap: 8px !important;\n  padding: 0 10px !important;\n}\n\n/* Quantity genişlesin */\nquantity-selector-component.quantity-selector {\n  width: 128px !important;\n  min-width: 128px !important;\n  max-width: 128px !important;\n  flex: 0 0 128px !important;\n}\n\n/* + / - daha içeride ve daha dengeli */\n.quantity-selector button {\n  width: 30px !important;\n  min-width: 30px !important;\n  max-width: 30px !important;\n  height: 30px !important;\n  min-height: 30px !important;\n  border-radius: 8px !important;\n  border: 0 !important;\n  background: transparent !important;\n  color: #2b251f !important;\n  opacity: 0.82 !important;\n  transition: background-color .18s ease, opacity .18s ease, transform .12s ease !important;\n}\n\n.quantity-selector button:hover {\n  background: rgba(43, 37, 31, 0.05) !important;\n  opacity: 1 !important;\n}\n\n/* Sayı alanı daha ferah */\n.quantity-selector input {\n  height: 34px !important;\n  font-size: 15px !important;\n  font-weight: 600 !important;\n  letter-spacing: -0.01em !important;\n  color: #2b251f !important;\n  background: transparent !important;\n  border: 0 !important;\n  text-align: center !important;\n  padding: 0 4px !important;\n}\n\n/* Buy now aynı yükseklik ve aynı tasarım ailesi */\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  height: 50px !important;\n  min-height: 50px !important;\n  border-radius: 14px !important;\n  background: linear-gradient(180deg, #2a241f 0%, #171310 100%) !important;\n  box-shadow:\n    0 1px 0 rgba(255,255,255,0.05) inset,\n    0 6px 14px rgba(0,0,0,0.12) !important;\n  transition: transform .18s ease, box-shadow .18s ease !important;\n}\n\n/* Buy now biraz daha geniş ve rahat */\n.shopify-payment-button__button,\n.shopify-payment-button__button--unbranded {\n  width: 164px !important;\n  min-width: 164px !important;\n  max-width: 164px !important;\n}\n\n.shopify-payment-button__button:hover,\n.shopify-payment-button__button--unbranded:hover {\n  transform: translateY(-1px) !important;\n  box-shadow:\n    0 1px 0 rgba(255,255,255,0.05) inset,\n    0 10px 18px rgba(0,0,0,0.14) !important;\n}\n</style>"
