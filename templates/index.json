        "custom_liquid_Gpa9Ed": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"ede-hero-overlay\">\n  <div class=\"ede-hero-inner\">\n    <h1>Handmade Barefoot Shoes for Grounded Living</h1>\n\n    <p class=\"ede-hero-subtitle\">\n      Soft leather. Natural movement. A more connected way to walk — handcrafted in small batches.\n    </p>\n\n    <p class=\"ede-hero-trust\">\n      Made by hand in Gaziantep, Turkey.\n    </p>\n\n    <div class=\"ede-hero-buttons\">\n      <a href=\"/collections/women\" class=\"ede-hero-btn ede-hero-btn-primary\">Shop Women</a>\n      <a href=\"/collections/men\" class=\"ede-hero-btn ede-hero-btn-secondary\">Shop Men</a>\n    </div>\n\n    <div class=\"ede-hero-features\">\n      <div class=\"ede-hero-feature\">\n        <span class=\"ede-hero-icon\">\n          <svg viewBox=\"0 0 80 80\" aria-hidden=\"true\">\n            <circle cx=\"40\" cy=\"40\" r=\"29\"></circle>\n            <path d=\"M34 58c-5-7.5-6.5-17.8-4.5-28.2 1.5-7.8 4.8-14.2 9.3-14.2 4.7 0 7.1 5.1 7.1 13.2v11.8c0 5.4 3.4 8.9 8.9 8.9h4.7\"></path>\n            <path d=\"M38.8 15.5V9.5\"></path>\n            <path d=\"M45.8 18.5l2.8-5.7\"></path>\n            <path d=\"M51.5 24.8l5-4\"></path>\n          </svg>\n        </span>\n        <span>Natural Foot Freedom</span>\n      </div>\n\n      <div class=\"ede-hero-feature\">\n        <span class=\"ede-hero-icon\">\n          <svg viewBox=\"0 0 80 80\" aria-hidden=\"true\">\n            <circle cx=\"40\" cy=\"40\" r=\"29\"></circle>\n            <path d=\"M40 31.5c-2.8-4.8-10.1-4.8-12.9 0-2.2 3.8-1 8.6 2.4 11.3L40 51.5l10.5-8.7c3.4-2.7 4.6-7.5 2.4-11.3-2.8-4.8-10.1-4.8-12.9 0z\"></path>\n            <path d=\"M27 50.5c-4.7 1.9-7.8 5-10 9.5\"></path>\n            <path d=\"M53 50.5c4.7 1.9 7.8 5 10 9.5\"></path>\n            <path d=\"M22 60h13\"></path>\n            <path d=\"M45 60h13\"></path>\n            <path d=\"M35 59l5-7.5 5 7.5\"></path>\n          </svg>\n        </span>\n        <span>Handmade Leather Craft</span>\n      </div>\n\n      <div class=\"ede-hero-feature\">\n        <span class=\"ede-hero-icon\">\n          <svg viewBox=\"0 0 80 80\" aria-hidden=\"true\">\n            <circle cx=\"40\" cy=\"40\" r=\"29\"></circle>\n            <path d=\"M23 56c20.5-1 35.5-15.8 40-37-20.5 1.2-35.8 16-40 37z\"></path>\n            <path d=\"M29.5 49.8c11-7.6 19.8-16.2 27-25.9\"></path>\n            <path d=\"M39 42.3c-3.1-.3-5.9-1-8.3-2.1\"></path>\n          </svg>\n        </span>\n        <span>Grounded by Design</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=Inter:wght@400;500&display=swap');\n\n  .shopify-section:has(.ede-hero-overlay) {\n    position: relative !important;\n  }\n\n  .ede-hero-overlay {\n    position: absolute !important;\n    inset: 0 !important;\n    z-index: 8 !important;\n    pointer-events: none !important;\n  }\n\n  .ede-hero-inner {\n    width: min(100%, 1440px) !important;\n    margin: 0 auto !important;\n    padding: 44px 76px 34px !important;\n    color: #5a3b2b !important;\n  }\n\n  .ede-hero-inner h1 {\n    max-width: 690px !important;\n    margin: 0 !important;\n    font-family: 'Cormorant Garamond', Georgia, serif !important;\n    font-size: clamp(56px, 5.4vw, 88px) !important;\n    line-height: 0.94 !important;\n    font-weight: 400 !important;\n    letter-spacing: -0.045em !important;\n    color: #5a3b2b !important;\n  }\n\n  .ede-hero-subtitle {\n    max-width: 530px !important;\n    margin: 28px 0 0 !important;\n    font-family: 'Inter', Arial, sans-serif !important;\n    font-size: 17px !important;\n    line-height: 1.52 !important;\n    color: rgba(90, 59, 43, 0.86) !important;\n  }\n\n  .ede-hero-trust {\n    margin: 22px 0 0 !important;\n    font-family: 'Cormorant Garamond', Georgia, serif !important;\n    font-size: 20px !important;\n    line-height: 1.2 !important;\n    color: rgba(90, 59, 43, 0.82) !important;\n  }\n\n  .ede-hero-trust::before {\n    content: \"⌁\" !important;\n    display: inline-block !important;\n    margin-right: 12px !important;\n    color: rgba(90, 59, 43, 0.65) !important;\n  }\n\n  .ede-hero-buttons {\n    display: flex !important;\n    gap: 18px !important;\n    margin-top: 30px !important;\n    pointer-events: auto !important;\n  }\n\n  .ede-hero-btn {\n    display: inline-flex !important;\n    align-items: center !important;\n    justify-content: center !important;\n    min-width: 178px !important;\n    height: 56px !important;\n    padding: 0 30px !important;\n    border-radius: 4px !important;\n    font-family: 'Inter', Arial, sans-serif !important;\n    font-size: 16px !important;\n    text-decoration: none !important;\n  }\n\n  .ede-hero-btn-primary {\n    background: #6a3d24 !important;\n    color: #fffaf5 !important;\n    border: 1px solid #6a3d24 !important;\n  }\n\n  .ede-hero-btn-secondary {\n    background: rgba(255,255,255,0.06) !important;\n    color: #5a3b2b !important;\n    border: 1px solid rgba(90, 59, 43, 0.36) !important;\n  }\n\n  .ede-hero-features {\n    display: flex !important;\n    gap: 82px !important;\n    margin-top: 56px !important;\n  }\n\n  .ede-hero-feature {\n    min-width: 165px !important;\n    text-align: center !important;\n    font-family: 'Cormorant Garamond', Georgia, serif !important;\n    font-size: 18px !important;\n    line-height: 1.2 !important;\n    color: rgba(90, 59, 43, 0.82) !important;\n  }\n\n  .ede-hero-icon {\n    display: flex !important;\n    align-items: center !important;\n    justify-content: center !important;\n    width: 54px !important;\n    height: 54px !important;\n    margin: 0 auto 12px !important;\n  }\n\n  .ede-hero-icon svg {\n    width: 54px !important;\n    height: 54px !important;\n    fill: none !important;\n    stroke: rgba(133, 94, 70, 0.9) !important;\n    stroke-width: 1.9 !important;\n    stroke-linecap: round !important;\n    stroke-linejoin: round !important;\n  }\n\n  .ede-hero-feature::after {\n    content: \"\" !important;\n    display: block !important;\n    width: 34px !important;\n    height: 1px !important;\n    margin: 13px auto 0 !important;\n    background: rgba(90, 59, 43, 0.3) !important;\n  }\n\n  @media screen and (max-width: 989px) {\n    .ede-hero-inner {\n      padding: 36px 24px 24px !important;\n    }\n\n    .ede-hero-inner h1 {\n      max-width: 430px !important;\n      font-size: clamp(42px, 9vw, 58px) !important;\n      line-height: 0.96 !important;\n    }\n\n    .ede-hero-subtitle {\n      max-width: 360px !important;\n      font-size: 15px !important;\n    }\n\n    .ede-hero-buttons {\n      gap: 12px !important;\n      flex-wrap: wrap !important;\n    }\n\n    .ede-hero-btn {\n      min-width: 148px !important;\n      height: 50px !important;\n      font-size: 15px !important;\n    }\n\n    .ede-hero-features {\n      gap: 18px !important;\n      width: 100% !important;\n      justify-content: space-between !important;\n    }\n\n    .ede-hero-feature {\n      min-width: 0 !important;\n      flex: 1 1 0 !important;\n      font-size: 14px !important;\n    }\n\n    .ede-hero-icon,\n    .ede-hero-icon svg {\n      width: 36px !important;\n      height: 36px !important;\n    }\n  }\n\n  @media screen and (max-width: 749px) {\n    .ede-hero-inner {\n      padding: 28px 18px 22px !important;\n    }\n\n    .ede-hero-inner h1 {\n      max-width: 320px !important;\n      font-size: clamp(38px, 10.6vw, 52px) !important;\n    }\n\n    .ede-hero-subtitle {\n      max-width: 295px !important;\n      font-size: 14px !important;\n    }\n\n    .ede-hero-buttons {\n      flex-direction: column !important;\n      align-items: flex-start !important;\n      max-width: 210px !important;\n    }\n\n    .ede-hero-btn {\n      width: 100% !important;\n      min-width: 0 !important;\n      height: 48px !important;\n    }\n\n    .ede-hero-features {\n      margin-top: 26px !important;\n      gap: 10px !important;\n    }\n\n    .ede-hero-feature {\n      font-size: 12px !important;\n    }\n\n    .ede-hero-icon,\n    .ede-hero-icon svg {\n      width: 30px !important;\n      height: 30px !important;\n    }\n  }\n/* FINAL ICON REFINEMENT */\n\n.ede-hero-features {\n  margin-top: 42px !important;\n}\n\n.ede-hero-icon,\n.ede-hero-icon svg {\n  width: 46px !important;\n  height: 46px !important;\n}\n\n.ede-hero-icon svg {\n  stroke: rgba(133, 94, 70, 0.72) !important;\n  stroke-width: 1.55 !important;\n}\n\n.ede-hero-icon svg circle {\n  stroke: rgba(133, 94, 70, 0.42) !important;\n  stroke-width: 1.45 !important;\n}\n\n.ede-hero-feature {\n  font-size: 17px !important;\n  color: rgba(90, 59, 43, 0.76) !important;\n}\n\n.ede-hero-feature::after {\n  margin-top: 11px !important;\n  background: rgba(90, 59, 43, 0.24) !important;\n}\n/* ICON VISIBILITY BALANCE */\n\n.ede-hero-icon,\n.ede-hero-icon svg {\n  width: 48px !important;\n  height: 48px !important;\n}\n\n.ede-hero-icon svg {\n  stroke: rgba(133, 94, 70, 0.82) !important;\n  stroke-width: 1.65 !important;\n}\n\n.ede-hero-icon svg circle {\n  stroke: rgba(133, 94, 70, 0.52) !important;\n  stroke-width: 1.45 !important;\n}\n\n.ede-hero-feature {\n  font-size: 17.5px !important;\n  color: rgba(90, 59, 43, 0.82) !important;\n}\n</style>"
