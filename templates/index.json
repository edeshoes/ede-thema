        "custom_liquid_Gpa9Ed": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"ede-hero-copy\">\n  <div class=\"ede-hero-copy__inner\">\n    <h1>Handmade Barefoot Shoes for Grounded Living</h1>\n\n    <p class=\"ede-hero-copy__subtitle\">\n      Soft leather. Natural movement. Grounded comfort — handcrafted in small batches.\n    </p>\n\n    <p class=\"ede-hero-copy__trust\">\n      Made by hand in Gaziantep, Turkey.\n    </p>\n\n    <div class=\"ede-hero-copy__buttons\">\n      <a href=\"/collections/women\" class=\"ede-hero-btn ede-hero-btn--primary\">Shop Women</a>\n      <a href=\"/collections/men\" class=\"ede-hero-btn ede-hero-btn--secondary\">Shop Men</a>\n    </div>\n\n    <div class=\"ede-hero-copy__features\">\n      <div class=\"ede-hero-feature\">\n        <span class=\"ede-hero-feature__icon\">♮</span>\n        <span>Natural Foot Freedom</span>\n      </div>\n\n      <div class=\"ede-hero-feature\">\n        <span class=\"ede-hero-feature__icon\">♡</span>\n        <span>Handmade Leather Craft</span>\n      </div>\n\n      <div class=\"ede-hero-feature\">\n        <span class=\"ede-hero-feature__icon\">◜</span>\n        <span>Grounded by Design</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=Inter:wght@400;500&display=swap');\n\n  .shopify-section:has(.ede-hero-copy) {\n    position: relative;\n  }\n\n  .ede-hero-copy {\n    position: absolute;\n    inset: 0;\n    z-index: 5;\n    pointer-events: none;\n    display: flex;\n    align-items: flex-start;\n  }\n\n  .ede-hero-copy__inner {\n    width: min(100%, 1480px);\n    margin: 0 auto;\n    padding: 38px 72px 34px;\n    color: #4a2f20;\n  }\n\n  .ede-hero-copy h1 {\n    max-width: 680px;\n    margin: 0;\n    font-family: 'Cormorant Garamond', Georgia, serif;\n    font-size: clamp(54px, 5vw, 88px);\n    line-height: 0.94;\n    font-weight: 400;\n    letter-spacing: -0.04em;\n    color: #4a2f20;\n  }\n\n  .ede-hero-copy__subtitle {\n    max-width: 520px;\n    margin: 28px 0 0;\n    font-family: 'Inter', Arial, sans-serif;\n    font-size: 18px;\n    line-height: 1.5;\n    font-weight: 400;\n    letter-spacing: -0.015em;\n    color: rgba(74, 47, 32, 0.82);\n  }\n\n  .ede-hero-copy__trust {\n    margin: 22px 0 0;\n    font-family: 'Inter', Arial, sans-serif;\n    font-size: 15px;\n    line-height: 1.4;\n    font-weight: 400;\n    letter-spacing: -0.01em;\n    color: rgba(74, 47, 32, 0.76);\n  }\n\n  .ede-hero-copy__trust::before {\n    content: \"⌁\";\n    display: inline-block;\n    margin-right: 10px;\n    color: rgba(90, 50, 31, 0.58);\n    font-size: 16px;\n  }\n\n  .ede-hero-copy__buttons {\n    display: flex;\n    gap: 18px;\n    margin-top: 30px;\n    pointer-events: auto;\n  }\n\n  .ede-hero-btn {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    min-width: 178px;\n    height: 56px;\n    padding: 0 30px;\n    border-radius: 4px;\n    font-family: 'Inter', Arial, sans-serif;\n    font-size: 16px;\n    line-height: 1;\n    font-weight: 400;\n    text-decoration: none;\n    transition: all .22s ease;\n  }\n\n  .ede-hero-btn--primary {\n    background: #5a321f;\n    color: #fffaf3;\n    border: 1px solid #5a321f;\n  }\n\n  .ede-hero-btn--secondary {\n    background: rgba(255,255,255,.08);\n    color: #4a2f20;\n    border: 1px solid rgba(74,47,32,.4);\n  }\n\n  .ede-hero-copy__features {\n    display: flex;\n    gap: 78px;\n    align-items: flex-start;\n    margin-top: 54px;\n  }\n\n  .ede-hero-feature {\n    min-width: 165px;\n    text-align: center;\n    font-family: 'Cormorant Garamond', Georgia, serif;\n    font-size: 18px;\n    line-height: 1.2;\n    font-weight: 400;\n    color: rgba(74, 47, 32, 0.78);\n    letter-spacing: -0.01em;\n  }\n\n  .ede-hero-feature__icon {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 42px;\n    height: 42px;\n    margin: 0 auto 12px;\n    font-family: 'Cormorant Garamond', Georgia, serif;\n    font-size: 36px;\n    line-height: 1;\n    font-weight: 400;\n    color: rgba(90, 50, 31, 0.62);\n  }\n\n  .ede-hero-feature::after {\n    content: \"\";\n    display: block;\n    width: 34px;\n    height: 1px;\n    margin: 14px auto 0;\n    background: rgba(90, 50, 31, 0.28);\n  }\n\n  @media screen and (max-width: 749px) {\n    .ede-hero-copy__inner {\n      padding: 42px 24px 28px;\n    }\n\n    .ede-hero-copy h1 {\n      max-width: 345px;\n      font-size: clamp(43px, 11vw, 58px);\n      line-height: 0.96;\n    }\n\n    .ede-hero-copy__subtitle {\n      max-width: 330px;\n      margin-top: 20px;\n      font-size: 15.5px;\n      line-height: 1.45;\n    }\n\n    .ede-hero-copy__trust {\n      margin-top: 16px;\n      font-size: 13.5px;\n    }\n\n    .ede-hero-copy__buttons {\n      flex-direction: column;\n      gap: 12px;\n      max-width: 300px;\n      margin-top: 24px;\n    }\n\n    .ede-hero-btn {\n      width: 100%;\n      height: 54px;\n      font-size: 15.5px;\n    }\n\n    .ede-hero-copy__features {\n      position: absolute;\n      left: 18px;\n      right: 18px;\n      bottom: 24px;\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 10px;\n      margin-top: 0;\n    }\n\n    .ede-hero-feature {\n      min-width: 0;\n      font-size: 12px;\n    }\n\n    .ede-hero-feature__icon {\n      width: 32px;\n      height: 32px;\n      margin-bottom: 8px;\n      font-size: 28px;\n    }\n\n    .ede-hero-feature::after {\n      width: 22px;\n      margin-top: 8px;\n    }\n  }\n</style>"
